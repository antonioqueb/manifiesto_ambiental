<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- FORMATO DE PÁGINA A4 SIN MÁRGENES -->
    <record id="paperformat_manifiesto_ambiental_sin_margen" model="report.paperformat">
        <field name="name">Manifiesto Ambiental Sin Margen</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">2</field>
        <field name="margin_bottom">3</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- ACCIÓN DEL REPORTE (Entrada) - SIN binding para que NO aparezca en el engrane -->
    <record id="action_report_manifiesto_ambiental" model="ir.actions.report">
        <field name="name">Manifiesto Ambiental (Entrada)</field>
        <field name="model">manifiesto.ambiental</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">manifiesto_ambiental.manifiesto_ambiental_document</field>
        <field name="report_file">manifiesto_ambiental.manifiesto_ambiental_document</field>
        <field name="paperformat_id" ref="manifiesto_ambiental.paperformat_manifiesto_ambiental_sin_margen"/>
    </record>

    <!-- PLANTILLA QWEB DEL REPORTE -->
    <template id="manifiesto_ambiental_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
                        <style>
                            @page { margin: 3mm 5mm 3mm 5mm; size: A4; }

                            body, td, th, strong, .labelcell, .subcell, .signature-text, .field-label {
                                font-family: "DejaVu Sans", Arial, "Liberation Sans", sans-serif !important;
                                font-size: 11px;
                                line-height: 1.12;
                                font-weight: 400 !important;
                                text-transform: none !important;
                            }

                            .page {
                                margin-top: 0 !important;
                                padding-top: 0 !important;
                            }

                            .header, .o_company_document_layout .header, .company_address, .o_company_address,
                            .external_layout .header, .address, .o_report_layout_standard .header,
                            .o_report_layout_boxed .header, .o_report_layout_clean .header {
                                display: none !important;
                                height: 0px !important;
                                margin: 0px !important;
                                padding: 0px !important;
                                border-bottom: none !important;
                            }

                            .footer, .o_company_document_layout .footer, .external_layout .footer, .o_footer {
                                display: none !important;
                                height: 0px !important;
                                padding: 0px !important;
                                margin: 0px !important;
                            }

                            .page-title {
                                text-align: center;
                                font-size: 12.5px;
                                font-weight: 700 !important;
                                margin: 0 0 4px;
                                font-family: "DejaVu Sans", Arial, sans-serif !important;
                                text-transform: uppercase !important;
                            }

                            table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 2px;
                                page-break-inside: avoid;
                            }

                            td, th {
                                border: 1px solid #666;
                                padding: 2px 3px;
                                font-size: 11px;
                                vertical-align: top;
                            }

                            th, .header-table, .labelcell, .subcell {
                                background: none !important;
                                font-weight: 400 !important;
                            }

                            th, .header-table {
                                text-align: center;
                            }

                            .labelcell {
                                font-size: 11px;
                            }

                            .subcell {
                                font-size: 10.8px;
                            }

                            strong, .field-label {
                                font-weight: 400 !important;
                            }

                            .value,
                            .labelcell .value,
                            .subcell .value,
                            .signature-fields .value,
                            td .value,
                            th .value {
                                font-weight: 700 !important;
                                text-transform: uppercase !important;
                            }

                            .gray-fill, .domicilio-cell, .header-table.gray-fill {
                                background: #eeeeee !important;
                            }

                            .header-table[rowspan] {
                                vertical-align: middle;
                            }

                            .no-border {
                                border: none !important;
                            }

                            .center-text {
                                text-align: center;
                            }

                            table.section-4 {
                                width: 100%;
                                border-collapse: collapse;
                                table-layout: fixed;
                            }

                            table.signature-section {
                                width: 100%;
                                border-collapse: separate;
                                border-spacing: 0;
                                margin-bottom: 2px;
                            }

                            table.signature-section > tbody > tr > td {
                                border: none !important;
                                padding: 0;
                            }

                            .signature-container {
                                border: 1px solid #666;
                                padding: 4px;
                            }

                            .signature-text {
                                margin: 0;
                                font-weight: 400 !important;
                            }

                            .signature-fields {
                                display: table;
                                width: 100%;
                                margin-top: 14px;
                            }

                            .signature-fields .cell {
                                display: table-cell;
                                vertical-align: top;
                                padding-right: 8px;
                                font-weight: 400 !important;
                            }

                            .signature-fields .cell:last-child {
                                padding-right: 0;
                            }

                            tr, td {
                                page-break-inside: avoid;
                            }
                        </style>

                        <!-- TÍTULO PRINCIPAL -->
                        <div class="page-title">
                            MANIFIESTO DE ENTREGA, TRANSPORTE Y RECEPCIÓN DE RESIDUOS PELIGROSOS (GENERADOR)
                        </div>

                        <!-- ENCABEZADO 1-3 -->
                        <table>
                            <tr>
                                <td class="labelcell" style="width:45%">
                                    1. Núm. de registro ambiental: <span class="value" t-field="doc.numero_registro_ambiental"/>
                                </td>
                                <td class="labelcell" style="width:40%">
                                    2. Núm. de manifiesto: <span class="value" t-field="doc.numero_manifiesto"/>
                                </td>
                                <td class="labelcell" style="width:15%">
                                    3. Página: <span class="value" t-field="doc.pagina"/>
                                </td>
                            </tr>
                        </table>

                        <!-- 4. GENERADOR -->
                        <table class="section-4">
                            <colgroup>
                                <col style="width:15%"/>
                                <col style="width:25%"/>
                                <col style="width:40%"/>
                                <col style="width:10%"/>
                                <col style="width:10%"/>
                            </colgroup>

                            <tr>
                                <td class="labelcell" colspan="5">
                                    4. Nombre o razón social del generador: <span class="value" t-field="doc.generador_nombre"/>
                                </td>
                            </tr>

                            <tr>
                                <td class="subcell domicilio-cell">Domicilio</td>
                                <td class="subcell">Código postal: <span class="value" t-field="doc.generador_codigo_postal"/></td>
                                <td class="subcell">Calle: <span class="value" t-field="doc.generador_calle"/></td>
                                <td class="subcell">Núm. ext.: <span class="value" t-field="doc.generador_num_ext"/></td>
                                <td class="subcell">Núm. int.: <span class="value" t-field="doc.generador_num_int"/></td>
                            </tr>

                            <tr>
                                <td class="subcell" colspan="2">
                                    Colonia: <span class="value" t-field="doc.generador_colonia"/>
                                </td>
                                <td class="subcell" colspan="1">
                                    Municipio o delegación: <span class="value" t-field="doc.generador_municipio"/>
                                </td>
                                <td class="subcell" colspan="2">
                                    Estado: <span class="value" t-field="doc.generador_estado"/>
                                </td>
                            </tr>

                            <tr>
                                <td class="subcell" colspan="2">
                                    Teléfono: <span class="value" t-field="doc.generador_telefono"/>
                                </td>
                                <td class="subcell" colspan="3">
                                    Correo electrónico: <span class="value" t-field="doc.generador_email"/>
                                </td>
                            </tr>
                        </table>

                        <!-- 5. IDENTIFICACIÓN DE LOS RESIDUOS -->
                        <table>
                            <colgroup>
                                <col style="width:22%"/>
                                <col style="width:3%"/>
                                <col style="width:3%"/>
                                <col style="width:3%"/>
                                <col style="width:3%"/>
                                <col style="width:3%"/>
                                <col style="width:3%"/>
                                <col style="width:3%"/>
                                <col style="width:5%"/>
                                <col style="width:10%"/>
                                <col style="width:10%"/>
                                <col style="width:10%"/>
                                <col style="width:3%"/>
                                <col style="width:3%"/>
                            </colgroup>

                            <tr>
                                <th colspan="14" class="header-table gray-fill">5. Identificación de los residuos</th>
                            </tr>
                            <tr>
                                <th class="header-table" rowspan="2">Nombre del residuo</th>
                                <th class="header-table" colspan="7">Clasificación</th>
                                <th class="header-table" colspan="3">Envase</th>
                                <th class="header-table" rowspan="2">Cantidad (kg)</th>
                                <th class="header-table" colspan="2">Etiqueta</th>
                            </tr>
                            <tr>
                                <th class="header-table">C</th>
                                <th class="header-table">R</th>
                                <th class="header-table">E</th>
                                <th class="header-table">T</th>
                                <th class="header-table">I</th>
                                <th class="header-table">B</th>
                                <th class="header-table">M</th>
                                <th class="header-table">Pzas</th>
                                <th class="header-table">Embalaje</th>
                                <th class="header-table">Capacidad</th>
                                <th class="header-table">Sí</th>
                                <th class="header-table">No</th>
                            </tr>

                            <t t-foreach="doc.residuo_ids" t-as="residuo">
                                <tr>
                                    <td><span class="value" t-field="residuo.nombre_residuo"/></td>
                                    <td class="center-text"><span class="value" t-if="residuo.clasificacion_corrosivo">X</span></td>
                                    <td class="center-text"><span class="value" t-if="residuo.clasificacion_reactivo">X</span></td>
                                    <td class="center-text"><span class="value" t-if="residuo.clasificacion_explosivo">X</span></td>
                                    <td class="center-text"><span class="value" t-if="residuo.clasificacion_toxico">X</span></td>
                                    <td class="center-text"><span class="value" t-if="residuo.clasificacion_inflamable">X</span></td>
                                    <td class="center-text"><span class="value" t-if="residuo.clasificacion_biologico">X</span></td>
                                    <td class="center-text"></td>

                                    <!-- Pzas: vacío cuando es 0 -->
                                    <td class="center-text">
                                        <span class="value" t-if="residuo.envase_cantidad" t-field="residuo.envase_cantidad"/>
                                    </td>

                                    <td class="center-text">
                                        <span class="value" t-if="residuo.packaging_id" t-field="residuo.packaging_id.name"/>
                                        <span class="value" t-elif="residuo.envase_tipo" t-field="residuo.envase_tipo"/>
                                    </td>

                                    <td class="center-text"><span class="value" t-field="residuo.envase_capacidad"/></td>

                                    <!-- Cantidad kg: vacío cuando es 0 -->
                                    <td class="center-text">
                                        <t t-if="residuo.cantidad">
                                            <span class="value" t-field="residuo.cantidad"/> <span class="value">KG</span>
                                        </t>
                                    </td>

                                    <td class="center-text"><span class="value" t-if="residuo.etiqueta_si">X</span></td>
                                    <td class="center-text"><span class="value" t-if="residuo.etiqueta_no">X</span></td>
                                </tr>
                            </t>

                            <t t-set="residuos_count" t-value="len(doc.residuo_ids)"/>
                            <t t-set="min_rows" t-value="18"/>
                            <t t-set="empty_rows" t-value="max(0, min_rows - residuos_count)"/>
                            <t t-foreach="range(empty_rows)" t-as="empty_row">
                                <tr style="height: 22px;">
                                    <td>&#160;</td><td>&#160;</td><td>&#160;</td><td>&#160;</td><td>&#160;</td>
                                    <td>&#160;</td><td>&#160;</td><td>&#160;</td><td>&#160;</td><td>&#160;</td>
                                    <td>&#160;</td><td>&#160;</td><td>&#160;</td><td>&#160;</td>
                                </tr>
                            </t>
                        </table>

                        <!-- 6. INSTRUCCIONES ESPECIALES -->
                        <table>
                            <tr>
                                <td class="labelcell">6. Instrucciones especiales e información adicional para el manejo seguro:</td>
                            </tr>
                            <tr>
                                <td style="height: 28px; vertical-align: top;">
                                    <span class="value" t-field="doc.instrucciones_especiales"/>
                                </td>
                            </tr>
                        </table>

                        <!-- 7. DECLARACIÓN DEL GENERADOR -->
                        <table class="signature-section">
                            <tr>
                                <td>
                                    <div class="signature-container">
                                        <div class="signature-text">
                                            7. Declaración del generador: Declaro bajo protesta de decir verdad que el contenido de este lote está total y correctamente descrito mediante el número de manifiesto, nombre del residuo, características CRETIB, debidamente envasado y etiquetado y que se han previsto las condiciones de seguridad para su transporte por vía terrestre de acuerdo con la legislación vigente.
                                        </div>
                                        <div class="signature-fields">
                                            <div class="cell" style="width:40%;">
                                                Nombre y firma del responsable:<br/>
                                                <span class="value" t-field="doc.generador_responsable_nombre"/>
                                            </div>
                                            <div class="cell" style="width:30%;">
                                                Fecha:<br/>
                                                <span class="value" t-field="doc.generador_fecha"/>
                                            </div>
                                            <div class="cell" style="width:30%;">
                                                Sello:<br/>
                                                <span class="value" t-field="doc.generador_sello"/>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- 8. TRANSPORTISTA -->
                        <table class="section-4">
                            <colgroup>
                                <col style="width:15%"/>
                                <col style="width:25%"/>
                                <col style="width:40%"/>
                                <col style="width:10%"/>
                                <col style="width:10%"/>
                            </colgroup>

                            <tr>
                                <td colspan="5" class="labelcell">8. Nombre o razón social del transportista: <span class="value" t-field="doc.transportista_nombre"/></td>
                            </tr>
                            <tr>
                                <td class="subcell domicilio-cell">Domicilio</td>
                                <td class="subcell">Código postal: <span class="value" t-field="doc.transportista_codigo_postal"/></td>
                                <td class="subcell">Calle: <span class="value" t-field="doc.transportista_calle"/></td>
                                <td class="subcell">Núm. ext.: <span class="value" t-field="doc.transportista_num_ext"/></td>
                                <td class="subcell">Núm. int.: <span class="value" t-field="doc.transportista_num_int"/></td>
                            </tr>
                            <tr>
                                <td class="subcell" colspan="2">Colonia: <span class="value" t-field="doc.transportista_colonia"/></td>
                                <td class="subcell">Municipio o delegación: <span class="value" t-field="doc.transportista_municipio"/></td>
                                <td class="subcell" colspan="2">Estado: <span class="value" t-field="doc.transportista_estado"/></td>
                            </tr>
                            <tr>
                                <td class="subcell" colspan="2">Teléfono: <span class="value" t-field="doc.transportista_telefono"/></td>
                                <td class="subcell" colspan="3">Correo electrónico: <span class="value" t-field="doc.transportista_email"/></td>
                            </tr>
                        </table>

                        <!-- 9-12. INFORMACIÓN DEL TRANSPORTE -->
                        <table>
                            <tr>
                                <td style="width:25%;">9. Núm. de autorización de la SEMARNAT:<br/><span class="value" t-field="doc.numero_autorizacion_semarnat"/></td>
                                <td style="width:25%;">10. Núm. de permiso S.C.T.:<br/><span class="value" t-field="doc.numero_permiso_sct"/></td>
                                <td style="width:25%;">11. Tipo de vehículo:<br/><span class="value" t-field="doc.tipo_vehiculo"/></td>
                                <td style="width:25%;">12. Núm. de placa:<br/><span class="value" t-field="doc.numero_placa"/></td>
                            </tr>
                        </table>

                        <!-- 13. RUTA -->
                        <table>
                            <tr>
                                <td class="labelcell">13. Ruta de la empresa generadora hasta su entrega:</td>
                            </tr>
                            <tr>
                                <td style="height: 28px; vertical-align: top;">
                                    <span class="value" t-field="doc.ruta_empresa"/>
                                </td>
                            </tr>
                        </table>

                        <!-- 14. DECLARACIÓN DEL TRANSPORTISTA -->
                        <table class="signature-section">
                            <tr>
                                <td>
                                    <div class="signature-container">
                                        <div class="signature-text">
                                            14. Declaración del transportista: Declaro bajo protesta de decir verdad que recibí los residuos peligrosos descritos en el manifiesto para su transporte a la empresa destinataria señalada por el generador.
                                        </div>
                                        <div class="signature-fields">
                                            <div class="cell" style="width:40%;">
                                                Nombre y firma del responsable:<br/>
                                                <span class="value" t-field="doc.transportista_responsable_nombre"/>
                                            </div>
                                            <div class="cell" style="width:30%;">
                                                Fecha:<br/>
                                                <span class="value" t-field="doc.transportista_fecha"/>
                                            </div>
                                            <div class="cell" style="width:30%;">
                                                Sello:<br/>
                                                <span class="value" t-field="doc.transportista_sello"/>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- 15. DESTINATARIO -->
                        <table class="section-4">
                            <colgroup>
                                <col style="width:15%"/>
                                <col style="width:25%"/>
                                <col style="width:40%"/>
                                <col style="width:10%"/>
                                <col style="width:10%"/>
                            </colgroup>

                            <tr>
                                <td colspan="5" class="labelcell">15. Nombre o razón social del destinatario: <span class="value" t-field="doc.destinatario_nombre"/></td>
                            </tr>
                            <tr>
                                <td class="subcell domicilio-cell">Domicilio</td>
                                <td class="subcell">Código postal: <span class="value" t-field="doc.destinatario_codigo_postal"/></td>
                                <td class="subcell">Calle: <span class="value" t-field="doc.destinatario_calle"/></td>
                                <td class="subcell">Núm. ext.: <span class="value" t-field="doc.destinatario_num_ext"/></td>
                                <td class="subcell">Núm. int.: <span class="value" t-field="doc.destinatario_num_int"/></td>
                            </tr>
                            <tr>
                                <td class="subcell" colspan="2">Colonia: <span class="value" t-field="doc.destinatario_colonia"/></td>
                                <td class="subcell">Municipio o delegación: <span class="value" t-field="doc.destinatario_municipio"/></td>
                                <td class="subcell" colspan="2">Estado: <span class="value" t-field="doc.destinatario_estado"/></td>
                            </tr>
                            <tr>
                                <td class="subcell" colspan="2">Teléfono: <span class="value" t-field="doc.destinatario_telefono"/></td>
                                <td class="subcell" colspan="3">Correo electrónico: <span class="value" t-field="doc.destinatario_email"/></td>
                            </tr>
                        </table>

                        <!-- 16-18. INFORMACIÓN ADICIONAL DEL DESTINATARIO -->
                        <table>
                            <tr>
                                <td style="width:50%;">16. Núm. autorización de la SEMARNAT:<br/><span class="value" t-field="doc.numero_autorizacion_semarnat_destinatario"/></td>
                                <td style="width:50%;">17. Nombre y cargo de la persona que recibe los residuos:<br/><span class="value" t-field="doc.nombre_persona_recibe"/></td>
                            </tr>
                            <tr>
                                <td colspan="2" class="labelcell">18. Observaciones:</td>
                            </tr>
                            <tr>
                                <td colspan="2" style="height: 28px; vertical-align: top;">
                                    <span class="value" t-field="doc.observaciones_destinatario"/>
                                </td>
                            </tr>
                        </table>

                        <!-- 19. DECLARACIÓN DEL DESTINATARIO -->
                        <table class="signature-section">
                            <tr>
                                <td>
                                    <div class="signature-container">
                                        <div class="signature-text">
                                            19. Declaración del destinatario: Declaro bajo protesta de decir verdad que recibí los residuos peligrosos descritos en el manifiesto.
                                        </div>
                                        <div class="signature-fields">
                                            <div class="cell" style="width:40%;">
                                                Nombre y firma del responsable:<br/>
                                                <span class="value" t-field="doc.destinatario_responsable_nombre"/>
                                            </div>
                                            <div class="cell" style="width:30%;">
                                                Fecha:<br/>
                                                <span class="value" t-field="doc.destinatario_fecha"/>
                                            </div>
                                            <div class="cell" style="width:30%;">
                                                Sello:<br/>
                                                <span class="value" t-field="doc.destinatario_sello"/>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>