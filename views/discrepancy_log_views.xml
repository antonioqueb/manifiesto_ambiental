<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_discrepancy_log_form_manifiesto" model="ir.ui.view">
        <field name="name">discrepancy.log.form.manifiesto</field>
        <field name="model">discrepancy.log</field>
        <field name="inherit_id" ref="gestion_discrepancias.view_discrepancy_log_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_manifiesto_discrepancia" type="object" class="oe_stat_button"
                        icon="fa-leaf" invisible="not manifiesto_discrepancia_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Discrepancia de Manifiesto</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
